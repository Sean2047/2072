---
import Base from '../layouts/Base.astro';
import { entries, BASE_DOC, url } from '../lib/data.mjs';

const features = [
  {
    href: url('/read/'), title: '全文阅读', status: '可用',
    desc: '按章节线性阅读世界观文档全文，节号引用自动链接到词条。',
  },
  {
    href: url('/entries/'), title: '词条库', status: '可用',
    desc: `${entries.length} 个词条：知识图谱导航 + 导览路径 + 检索筛选，三层渐进披露。`,
  },
  {
    href: url('/objections/'), title: '反对文集', status: '筹备中',
    desc: '为什么《2072》可能是错的——对承重假设的系统性反驳，与正文平级对峙。',
  },
  {
    href: url('/documents/'), title: '文内文献', status: '筹备中',
    desc: '教材节选、用户手册、社论与口述史——来自那个世界内部的文本。',
  },
  {
    href: url('/slice/'), title: '时空断面', status: '规划中',
    desc: '输入时间与地点，生成该断面的世界状态——故事与游戏的背景系统。',
  },
  {
    href: url('/stories/'), title: '故事', status: '筹备中',
    desc: '基于 2072 世界观的小说与场景创作。',
  },
  {
    href: url('/games/'), title: '游戏', status: '筹备中',
    desc: '宏观策略 / 城市模拟 / 叙事探索三个方向的游戏化探索。',
  },
  {
    href: url('/discuss/'), title: '讨论', status: '可用',
    desc: '对世界观设定的疑问、指摘与推演，欢迎在此讨论。',
  },
];
---
<Base title="首页" active="home">
  <header class="hero home-hero">
    <h1>《2072》</h1>
    <p class="home-tagline">一部关于 2026—2076 年的世界观文档</p>
    <div class="home-intro">
      <p>
        本站推演一个问题：当 AI 承担大部分劳动、聚变能源接近免费之后，社会靠什么继续运转？
        文档给出的答案是<strong>多态社会</strong>——不再有单一的主流生活方式，人们分散进各类社区，
        彼此差异巨大，却在"相互忽视"中达成均衡。
      </p>
      <p>
        推演覆盖七类国家路径（A1 / A2 / B1 / B2 / C / D / E）在五十年间的分化，
        以八个核心变量与因果链驱动，区分机制推演与历史事实，标注每一处不确定性。
        它不是预言，是一个可检验、可引用、可用于创作的推演框架。
      </p>
    </div>
  </header>

  <div class="feature-grid">
    {features.map((f) => (
      <a class="feature-card" href={f.href}>
        <div class="feature-top">
          <h3>{f.title}</h3>
          <span class={`fstatus ${f.status === '可用' ? 'on' : 'off'}`}>{f.status}</span>
        </div>
        <p>{f.desc}</p>
      </a>
    ))}
  </div>

  <p class="home-foot">基准文档 {BASE_DOC.replace('.md', '')} · 词条与全文内容零改写，均由构建自动生成</p>
</Base>
